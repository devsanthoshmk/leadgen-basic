meta {
  name: Autocomplete
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/searches/autocomplete?password={{password}}&q=rest&limit=5
}

headers {
  Content-Type: application/json
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });

  test("should return suggestions array", function() {
    expect(res.body.suggestions).to.be.an('array');
  });
}

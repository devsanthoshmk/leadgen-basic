meta {
  name: Save Search - Invalid Body
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/searches?password={{password}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "invalid": "data"
  }
}

tests {
  test("should return 400 for invalid body", function() {
    expect(res.status).to.equal(400);
  });

  test("should return validation error", function() {
    expect(res.body.error).to.contain("query");
  });
}

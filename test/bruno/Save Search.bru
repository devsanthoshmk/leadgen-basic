meta {
  name: Save Search
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/searches?password={{password}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "query": "restaurants in Chennai",
    "mode": "normal",
    "results": [
      {
        "title": "Test Restaurant",
        "cid": "12345",
        "stars": 4.5,
        "reviews": 120,
        "category": "Restaurant",
        "address": "123 Test St, Chennai",
        "completePhoneNumber": "+91-9876543210",
        "url": "https://example.com"
      },
      {
        "title": "Another Place",
        "cid": "67890",
        "stars": 3.8,
        "reviews": 45,
        "category": "Cafe",
        "address": "456 Demo Rd, Chennai",
        "completePhoneNumber": "+91-9123456789",
        "url": "https://example2.com"
      }
    ]
  }
}

tests {
  test("should return 201", function() {
    expect(res.status).to.equal(201);
  });

  test("should return search id and results count", function() {
    expect(res.body.id).to.be.a('number');
    expect(res.body.resultsCount).to.equal(2);
  });
}

script:post-response {
  bru.setVar("searchId", res.body.id);
}

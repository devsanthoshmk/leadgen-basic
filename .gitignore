# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

# Node/Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS/System
.DS_Store
Thumbs.db
$RECYCLE.BIN/
UserInterfaceState.xcuserstate

# Logs and databases
*.log
log.txt
*.sqlite

# IDE/Editor
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
*.sublime-project
*.sublime-workspace
*~
*.sw[mnpcod]

# Build/Output
/dist
/www
/coverage
/.sourcemaps
/.tmp
*.tmp
*.tmp.*

# Ionic/Capacitor
/.ionic
/.sass-cache
/.versions
/platforms
/plugins

# Environment variables
.env
.env.*
!.env.example

# Signing/Secrets
release.keystore
release.keystore.b64
*.cer
*.p12
*.pfx
